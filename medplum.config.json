{
  "port": "${PORT}",
  "baseUrl": "https://medplum-production-dff0.up.railway.app",
  "appBaseUrl": "https://medplum-production-dff0.up.railway.app",
  "binaryStorage": "file:/app/binary/",
  "storageBaseUrl": "https://medplum-production-dff0.up.railway.app/storage/",
  "allowedOrigins": "*",
  "introspectionEnabled": true,

  "database": {
    "host": "${PGHOST}",
    "port": "${PGPORT}",
    "dbname": "${PGDATABASE}",
    "username": "${PGUSER}",
    "password": "${PGPASSWORD}",
    "ssl": true
  },

  "redis": {
    "url": "${REDIS_URL}"
  },

  "logLevel": "info"
}