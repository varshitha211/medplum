{
  "port": "${PORT}",
  "baseUrl": "https://medplum-production-dff0.up.railway.app",
  "binaryStorage": "file:./binary/",
  "storageBaseUrl": "https://medplum-production-dff0.up.railway.app/storage/",
  "supportEmail": "\"Medplum\" <support@medplum.com>",
  "allowedOrigins": "*",
  "introspectionEnabled": true,
  "database": {
    "type": "postgresql",
    "url": "${DATABASE_URL}"
  },
  "redis": {
    "url": "${REDIS_URL}"
  },
  "bullmq": {
    "removeOnFail": { "count": 1 },
    "removeOnComplete": { "count": 1 }
  },
  "shutdownTimeoutMilliseconds": 30000
}